{
	"name": "my-first-worker",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "npm run build:wasm",
		"build:wasm": "sh -c 'OUT_DIR=\"$(pwd)/build\"; mkdir -p \"$OUT_DIR\"; cd ../../api && GOOS=wasip1 GOARCH=wasm go build -o \"$OUT_DIR/main.wasm\" ./cmd/wasm'",
		"predeploy": "npm run build:wasm",
		"deploy": "npm install && wrangler deploy",
		"predev": "npm run build:wasm",
		"dev": "wrangler dev",
		"prestart": "npm run build:wasm",
		"start": "wrangler dev",
		"test": "vitest"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"vitest": "~3.2.0",
		"wrangler": "^4.70.0"
	},
	"dependencies": {
		"@bjorn3/browser_wasi_shim": "^0.4.2"
	}
}
